{
  "crons": [
    {
      "path": "/api/cron/send-daily-digest",
      "schedule": "5 18 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/ads.txt",
      "destination": "https://www.trendpulse.life/ads.txt",
      "permanent": true
    },
    {
      "source": "/:splat*",
      "has": [
        {
          "type": "host",
          "value": "trendpulse.life"
        }
      ],
      "destination": "https://www.trendpulse.life/:splat*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}